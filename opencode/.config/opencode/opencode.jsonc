{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3"
  ],
  "model": "amazon-bedrock/eu.anthropic.claude-sonnet-4-6",
  "autoupdate": true,
  "permission": {
    "*": "allow",
  },
  "provider": {
    "amazon-bedrock": {
      "models": {
        "arn:aws:bedrock:eu-central-1:328991713846:inference-profile/eu.anthropic.claude-sonnet-4-6": {
          "id": "arn:aws:bedrock:eu-central-1:328991713846:inference-profile/eu.anthropic.claude-sonnet-4-6"
        },
        "arn:aws:bedrock:us-east-1:334450016200:inference-profile/global.anthropic.claude-opus-4-6-v1": {
          "id": "arn:aws:bedrock:us-east-1:334450016200:inference-profile/global.anthropic.claude-opus-4-6-v1"
        }
      },
      "options": {
        "region": "eu-central-1",
        "profile": "innio-ai-devs"
      }
    }
  },
  "mcp": {
    "atlassian": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
    },
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension"
      ],
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GH_PWA}"
      }
    },
    "myplant": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:3001/mcp",
      "oauth": {}
    },
    "groundcover": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote@0.1.30",
        "https://mcp.groundcover.com/api/mcp",
        "54278",
        "--header",
        "X-Timezone:Europe/Vienna",
        "--header",
        "X-Tenant-UUID:b266993b-005a-4d94-b653-3eb16cb901b6",
        "--header",
        "X-Backend-Id:groundcover"
      ]
    },
    "ms365": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@softeria/ms-365-mcp-server",
        "--toon",
        "--org-mode"
      ],
      "environment": {
        "MS365_MCP_CLIENT_ID": "{env: MS365_MCP_CLIENT_ID}",
        "MS365_MCP_TENANT_ID": "{env: MS365_MCP_TENANT_ID}",
        "MS365_MCP_CLIENT_SECRET": "{env: MS365_MCP_CLIENT_SECRET}"
      }
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      }
    }
    // "chrome-devtools": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "-y",
    //     "chrome-devtools-mcp@latest",
    //     "--autoConnect"
    //   ]
    // },
    // https://github.com/sooperset/mcp-atlassian?tab=readme-ov-file
    // "mcp-atlassian": {
    //   "enabled": false,
    //   "type": "local",
    //   "command": [
    //     "uvx",
    //     "mcp-atlassian@v0.13.1"
    //   ],
    //   "environment": {
    //     "JIRA_URL": "{env:JIRA_URL}",
    //     "JIRA_USERNAME": "{env:JIRA_USERNAME}",
    //     "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
    //     "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
    //     "CONFLUENCE_USERNAME": "{env:CONFLUENCE_USERNAME}",
    //     "CONFLUENCE_API_TOKEN": "{env:JIRA_API_TOKEN}"
    //   }
    // },
  }
}
